<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.ui.layout.form">
  <Dialog id="publishDialog" title="{i18n>publishDialogTitle}" type="Message">
    <content>
      <VBox class="sapUiSmallMargin">
        <Text text="{= ${editor>/validationIssues}.length + ' issue(s) found' }" />
        <Label text="{i18n>publishComment}" labelFor="publishCommentInput" />
        <TextArea id="publishCommentInput" rows="3" width="100%" value="{publish>/comment}" />
      </VBox>
    </content>
    <beginButton>
      <Button
        text="{i18n>publishConfirm}"
        type="Emphasized"
        enabled="{= !${editor>/hasValidationErrors} }"
        press="onPublishConfirm" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press="onPublishCancel" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>
