<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">
  <Table
    items="{
      path: '/AuditEvents',
      filters: [{
        path: 'model_ID',
        operator: 'EQ',
        value1: '{editor>/modelId}'
      }],
      sorter: { path: 'createdAt', descending: true }
    }"
    growing="true"
    growingScrollToLoad="true"
    noDataText="{i18n>emptyAudit}">
    <columns>
      <Column><Text text="{i18n>colEvent}" /></Column>
      <Column><Text text="{i18n>colActor}" /></Column>
      <Column><Text text="{i18n>colDetails}" /></Column>
      <Column><Text text="{i18n>colModifiedAt}" /></Column>
    </columns>
    <items>
      <ColumnListItem>
        <cells>
          <Text text="{eventType}" />
          <Text text="{actor}" />
          <Text text="{details}" />
          <Text text="{createdAt}" />
        </cells>
      </ColumnListItem>
    </items>
  </Table>
</core:FragmentDefinition>
